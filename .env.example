# Ferret — environment variable template
# Copy to .env and fill in your values. Never commit .env.

# Discovery API (required)
DISCOVERY_API_URL=http://localhost:8092

# LLM gateway (required) — any OpenAI-compatible endpoint with tool call support
LLM_GATEWAY_URL=http://localhost:8090
DISCOVERY_LLM_MODEL=deepseek-chat

# Blockchain RPC endpoints
DISCOVERY_SUI_RPC=https://fullnode.mainnet.sui.io:443
DISCOVERY_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Tuning
DISCOVERY_MAX_TOOL_CALLS=30
DISCOVERY_MAX_NEW_HOSTS=10
DISCOVERY_MAX_IDLE_CALLS=15
DISCOVERY_PROBE_RATE_LIMIT=50

# Optional: OSINT tools
GITHUB_TOKEN=
SERP_API_KEY=
